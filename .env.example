# ═══════════════════════════════════════════════════════
# GeoTrack Environment Configuration
# Copy to .env for local development
# ═══════════════════════════════════════════════════════

# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database (PostgreSQL + PostGIS + TimescaleDB)
DATABASE_URL=postgresql://geotrack:geotrack_dev@localhost:5432/geotrack?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka / Redpanda
KAFKA_BROKERS=localhost:9092

# JWT
JWT_SECRET=dev-secret-change-in-production-minimum-32-chars!!
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true

# Tracking
TRACKING_MAX_BATCH_SIZE=100
TRACKING_MAX_SPEED_KMH=200
TRACKING_ACCURACY_THRESHOLD_M=50
