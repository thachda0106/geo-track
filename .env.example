# ═══════════════════════════════════════════════════════
# GeoTrack Environment Configuration
# Copy to .env for local development
# ═══════════════════════════════════════════════════════

# App
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database (PostgreSQL + PostGIS + TimescaleDB)
# App connects via PgBouncer for connection pooling (port 6432)
DATABASE_URL=postgresql://geotrack:geotrack_dev@localhost:6432/geotrack?schema=public&pgbouncer=true
# Direct connection for Prisma migrations (bypasses PgBouncer)
DIRECT_URL=postgresql://geotrack:geotrack_dev@localhost:5433/geotrack?schema=public
# Disable prepared statement caching when using PgBouncer in transaction mode
PRISMA_PREPARED_STATEMENT_CACHING=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka / Redpanda
KAFKA_BROKERS=localhost:9092

# JWT
JWT_SECRET=dev-secret-change-in-production-minimum-32-chars!!
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging & Observability
LOG_LEVEL=debug
LOG_PRETTY=true
# SENTRY_DSN=https://key@o111.ingest.sentry.io/project

# Tracking
TRACKING_MAX_BATCH_SIZE=100
TRACKING_MAX_SPEED_KMH=200
TRACKING_ACCURACY_THRESHOLD_M=50

# Ingest API Key (IoT device authentication)
INGEST_API_KEY=change-me-in-production-minimum-32-characters-long!!
