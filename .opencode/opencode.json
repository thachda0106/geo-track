{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "tools": {
    "bash": true,
    "read": true,
    "glob": true,
    "grep": true,
    "edit": true,
    "write": true,
    "task": true,
    "webfetch": true,
    "todowrite": true,
    "question": true
  },
  "mcp": {
    "prisma-mcp-server": {
      "type": "local",
      "command": ["npx", "-y", "prisma", "mcp"],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@2.0.2"],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code"
      ],
      "enabled": true
    },
    "postgres-mcp": {
      "type": "local",
      "command": ["uvx", "postgres-mcp", "--access-mode=unrestricted"],
      "enabled": true,
      "environment": {
        "DATABASE_URI": "postgresql://postgres:123456@localhost:5432/postgres"
      }
    },
    "pdf-reader-mcp": {
      "type": "local",
      "command": ["npx", "-y", "-q", "@sylphx/pdf-reader-mcp"],
      "enabled": true
    }
  }
}
