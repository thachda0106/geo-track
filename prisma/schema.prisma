// This is your Prisma schema file.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, uuid_ossp(map: "uuid-ossp")]
  schemas    = ["identity", "geometry", "versioning", "tracking", "public"]
}

// ═══════════════════════════════════════════════════════
// IDENTITY SCHEMA
// ═══════════════════════════════════════════════════════

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  displayName  String   @map("display_name") @db.VarChar(100)
  role         String   @default("viewer") @db.VarChar(20)
  status       String   @default("active") @db.VarChar(20)
  lastLoginAt  DateTime? @map("last_login_at") @db.Timestamptz()
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@map("users")
  @@schema("identity")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
  @@schema("identity")
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(50)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent")
  details   Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@map("audit_log")
  @@schema("identity")
}

// ═══════════════════════════════════════════════════════
// GEOMETRY SCHEMA
// Note: PostGIS geometry columns and spatial indexes
// are managed via raw SQL migrations (Prisma doesn't
// natively support PostGIS geometry types)
// ═══════════════════════════════════════════════════════

model Feature {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String   @db.VarChar(255)
  description    String?  @db.Text
  geometryType   String   @map("geometry_type") @db.VarChar(20)
  // geometry column managed via raw SQL (PostGIS GEOMETRY type)
  properties     Json     @default("{}")
  tags           String[] @default([])
  currentVersion Int      @default(1) @map("current_version")
  createdBy      String   @map("created_by") @db.Uuid
  updatedBy      String   @map("updated_by") @db.Uuid
  isDeleted      Boolean  @default(false) @map("is_deleted")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz()
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([geometryType])
  @@index([createdBy])
  @@index([updatedAt(sort: Desc)])
  @@map("features")
  @@schema("geometry")
}

model Outbox {
  id            BigInt    @id @default(autoincrement())
  eventType     String    @map("event_type") @db.VarChar(100)
  aggregateId   String    @map("aggregate_id") @db.Uuid
  aggregateType String    @default("Feature") @map("aggregate_type") @db.VarChar(50)
  payload       Json
  correlationId String    @map("correlation_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  publishedAt   DateTime? @map("published_at") @db.Timestamptz()
  retryCount    Int       @default(0) @map("retry_count")
  maxRetries    Int       @default(3) @map("max_retries")
  lastError     String?   @map("last_error") @db.Text
  failedAt      DateTime? @map("failed_at") @db.Timestamptz()

  @@index([createdAt])
  @@map("outbox")
  @@schema("geometry")
}

model OutboxDlq {
  id            BigInt    @id @default(autoincrement())
  originalId    BigInt    @map("original_id")
  eventType     String    @map("event_type") @db.VarChar(100)
  aggregateId   String    @map("aggregate_id") @db.Uuid
  payload       Json
  errorMessage  String    @map("error_message") @db.Text
  retryCount    Int       @map("retry_count")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  @@map("outbox_dlq")
  @@schema("geometry")
}
// ═══════════════════════════════════════════════════════
// VERSIONING SCHEMA
// ═══════════════════════════════════════════════════════

model Version {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  featureId          String   @map("feature_id") @db.Uuid
  versionNumber      Int      @map("version_number")
  changeType         String   @map("change_type") @db.VarChar(20)
  // snapshot_geometry managed via raw SQL (PostGIS GEOMETRY type)
  snapshotProperties Json     @default("{}") @map("snapshot_properties")
  snapshotName       String   @map("snapshot_name") @db.VarChar(255)
  diff               Json?
  authorId           String   @map("author_id") @db.Uuid
  message            String?  @db.Text
  parentVersionId    String?  @map("parent_version_id") @db.Uuid
  vertexCount        Int?     @map("vertex_count")
  areaSqm            Float?   @map("area_sqm")
  lengthM            Float?   @map("length_m")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()

  parentVersion Version?  @relation("VersionChain", fields: [parentVersionId], references: [id])
  childVersions Version[] @relation("VersionChain")

  @@unique([featureId, versionNumber])
  @@index([featureId, versionNumber(sort: Desc)])
  @@index([authorId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("versions")
  @@schema("versioning")
}

model Changeset {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authorId     String   @map("author_id") @db.Uuid
  message      String   @db.Text
  versionIds   String[] @map("version_ids") @db.Uuid
  featureCount Int      @map("feature_count")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([authorId, createdAt(sort: Desc)])
  @@map("changesets")
  @@schema("versioning")
}

model Inbox {
  eventId     String   @id @map("event_id") @db.Uuid
  eventType   String   @map("event_type") @db.VarChar(100)
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz()

  @@index([processedAt])
  @@map("inbox")
  @@schema("versioning")
}

// ═══════════════════════════════════════════════════════
// TRACKING SCHEMA
// Note: location_points table is managed via raw SQL
// (TimescaleDB hypertable — Prisma doesn't support this)
// ═══════════════════════════════════════════════════════

model TrackingSession {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId           String    @map("device_id") @db.Uuid
  ownerId            String    @map("owner_id") @db.Uuid
  status             String    @default("active") @db.VarChar(20)
  minIntervalMs      Int       @default(1000) @map("min_interval_ms")
  maxSpeedKmh        Float     @default(200) @map("max_speed_kmh") @db.Real
  accuracyThresholdM Float     @default(50) @map("accuracy_threshold_m") @db.Real
  trackingMode       String    @default("continuous") @map("tracking_mode") @db.VarChar(20)
  totalPoints        BigInt    @default(0) @map("total_points")
  totalDistanceM     Float     @default(0) @map("total_distance_m")
  lastLocationAt     DateTime? @map("last_location_at") @db.Timestamptz()
  lastLat            Float?    @map("last_lat")
  lastLng            Float?    @map("last_lng")
  startedAt          DateTime  @default(now()) @map("started_at") @db.Timestamptz()
  endedAt            DateTime? @map("ended_at") @db.Timestamptz()
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  tracks Track[]

  @@index([deviceId, status])
  @@index([ownerId, createdAt(sort: Desc)])
  @@map("sessions")
  @@schema("tracking")
}

model Track {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId    String    @map("session_id") @db.Uuid
  segmentIndex Int       @default(0) @map("segment_index")
  startTime    DateTime  @map("start_time") @db.Timestamptz()
  endTime      DateTime? @map("end_time") @db.Timestamptz()
  pointCount   BigInt    @default(0) @map("point_count")
  distanceM    Float     @default(0) @map("distance_m")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  session TrackingSession @relation(fields: [sessionId], references: [id])

  @@unique([sessionId, segmentIndex])
  @@index([sessionId, segmentIndex])
  @@map("tracks")
  @@schema("tracking")
}
