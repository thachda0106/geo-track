{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": ".*\\.integration\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@app/core(.*)$": "<rootDir>/libs/core/src$1",
    "^@app/shared(.*)$": "<rootDir>/libs/shared/src$1"
  },
  "collectCoverageFrom": [
    "src/**/*.(t|j)s",
    "libs/**/*.(t|j)s",
    "!**/*.spec.ts",
    "!**/*.integration.spec.ts"
  ],
  "coverageDirectory": "./coverage/integration",
  "testEnvironment": "node"
}
